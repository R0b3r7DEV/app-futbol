# Fuente de datos:
#   "openfootball" → GRATIS y sin límites, Mundial 2026 real, pero solo goles
#                    (calendario + resultados) → únicamente mercado 1X2.
#   "apifootball"  → goles + córners + disparos (los 3 mercados), pero la
#                    temporada 2026 requiere plan de pago (free: solo 2022-2024).
DATA_SOURCE=openfootball

# Temporada a analizar (2026 = Mundial; 2022/2023/2024 accesibles en api-football free).
MUNDIAL_SEASON=2026

# Clave de API-Football (api-sports.io). Solo si DATA_SOURCE=apifootball. Free: 100 req/día.
API_FOOTBALL_KEY=

# Supabase: URL pública (usada por el cliente del navegador) y de servidor.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=

# Clave service_role de Supabase: SOLO backend. Omite RLS, NUNCA exponer al cliente.
SUPABASE_SERVICE_KEY=
